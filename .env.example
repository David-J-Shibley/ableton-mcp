# Disable upstream telemetry (recommended for local fork)
ABLETON_MCP_DISABLE_TELEMETRY=true

# Socket connection to the Ableton Remote Script (defaults shown)
ABLETON_HOST=localhost
ABLETON_PORT=9877

# Pipeline paths — Suno WAVs in, mastered WAVs out for DistroKid
ABLETON_IMPORT_DIR=~/.suno-mcp/downloads
ABLETON_EXPORT_DIR=~/.distrokid-mcp/prepared-audio
